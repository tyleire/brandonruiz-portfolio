# Copy this to .env.local and fill in the values

# Admin password (set to whatever you want)
ADMIN_PASSWORD=brandon2025

# Vercel Blob token — get from Vercel dashboard → Storage → Blob → your store → .env.local
# Required for admin save + image uploads in production
BLOB_READ_WRITE_TOKEN=

# Session secret — any random 32+ char string
SESSION_SECRET=change-this-to-a-random-secret-string-32chars
